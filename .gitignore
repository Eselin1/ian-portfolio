# Dependency directories
node_modules/

# Vite build output
dist/
.vite/

# Build artifacts (in case of TypeScript)
*.tsbuildinfo

# Environment variables and local secrets
.env
.env.*
!.env.example
.dev.vars
.dev.vars.*

# Log files
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# System files
.DS_Store
Thumbs.db

# IDE/Editor configs
.vscode/*
!.vscode/settings.json
!.vscode/css_custom_data.json
.idea/
*.sw?
*.iml

# OS/Terminal files
*.log
*.pid
*.seed
*.tgz
*.orig
*.suo
*.ntvs*
*.njsproj
*.sln

# Optional: Mac zip artifacts and temp
*.zip
*.tmp

# Optional: Ignore storybook or testing outputs
.storybook-out/
coverage/
.eslintcache

# Platform-local state
.vercel/
.wrangler/
